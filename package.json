{
  "name": "@aryanbansal-launch/edge-utils",
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/AryanBansal-launch/launch-edge-utils.git"
  },
  "homepage": "https://github.com/AryanBansal-launch/launch-edge-utils#readme",
  "bugs": {
    "url": "https://github.com/AryanBansal-launch/launch-edge-utils/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "create-launch-edge": "bin/launch-init.js",
    "launch-config": "bin/launch-config.js",
    "launch-help": "bin/launch-help.js",
    "launch-edge-local": "./bin/launch-edge-local.js",
    "launch-edge-test-local": "./bin/launch-edge-test-local.js",
    "launch-edge-seed-local": "./bin/launch-edge-seed-local.js",
    "launch-edge-quickstart": "./bin/launch-edge-quickstart.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "optionalDependencies": {
    "wrangler": "^3.114.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "bin",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "contentstack",
    "launch",
    "edge-functions",
    "edge",
    "middleware",
    "security",
    "nextjs",
    "redirect",
    "geo-location",
    "basic-auth",
    "ip-access"
  ]
}
